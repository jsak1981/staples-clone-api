<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Define properties for reuse -->
    <property name="LOGS_DIR" value="logs" />
    <property name="LOG_ARCHIVE" value="${LOGS_DIR}/archived" />
    <!-- Updated LOG_PATTERN to include both correlationId and requestId -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [corrId:%X{correlationId} | reqId:%X{requestId}] - %msg%n" />

    <!-- Appender to log to the console -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Updated pattern for console with both IDs -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) [%yellow(corrId:%X{correlationId} | reqId:%X{requestId})] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender to log to a rolling file -->
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS_DIR}/staples-staples_clone.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_ARCHIVE}/staples-staples_clone.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Root logger configuration -->
    <root level="info">
        <appender-ref ref="Console" />
        <appender-ref ref="RollingFile" />
    </root>

    <!-- Application-specific logger configuration -->
    <logger name="com.staples.staples_clone" level="debug" additivity="false">
        <appender-ref ref="Console" />
        <appender-ref ref="RollingFile" />
    </logger>

</configuration>

